# ===============================

backend/node_modules/
backend/.env
backend/dist/
backend/build/

# WireGuard keys & configs (very important)
backend/*.key
backend/*.pub
backend/*.conf

# ===============================
# Frontend (React)
# ===============================

frontend/node_modules/
frontend/build/
frontend/.env

# ===============================
# Scripts Folder
# ===============================

scripts/*.key
scripts/*.pub
scripts/*.conf
scripts/*.log

